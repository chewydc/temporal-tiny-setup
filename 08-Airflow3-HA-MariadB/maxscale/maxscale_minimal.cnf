[maxscale]
threads=auto
admin_host=0.0.0.0
admin_port=8989
admin_secure_gui=false

# Monitor
[MariaDB-Monitor]
type=monitor
module=mariadbmon
servers=mariadb-primary,mariadb-replica
user=maxscale_monitor
password=maxscale_monitor_pass
monitor_interval=5s

# Service
[ReadWriteSplit-Service]
type=service
router=readwritesplit
servers=mariadb-primary,mariadb-replica
user=maxscale_router
password=maxscale_router_pass

# Listener
[ReadWriteSplit-Listener]
type=listener
service=ReadWriteSplit-Service
protocol=MariaDBClient
port=4006

# Servers
[mariadb-primary]
type=server
address=mariadb-primary
port=3306

[mariadb-replica]
type=server
address=mariadb-replica
port=3306