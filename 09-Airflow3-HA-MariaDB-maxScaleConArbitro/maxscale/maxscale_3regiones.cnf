# ============================================================================
# MAXSCALE CONFIGURATION - BASADO EN PRODUCCION
# ============================================================================
# Configuración simplificada y probada en producción
# ============================================================================

[maxscale]
threads=auto

# ============================================================================
# SERVIDORES - 3 REGIONES
# ============================================================================

[HORNOS]
type=server
address=mariadb-primary-hornos
port=3306
protocol=MariaDBBackend

[SANLORENZO]
type=server
address=mariadb-replica-sanlorenzo
port=3306
protocol=MariaDBBackend

[TUCUMAN]
type=server
address=mariadb-arbitrator-tucuman
port=3306
protocol=MariaDBBackend

# ============================================================================
# MONITOR - Replicación con Arbitrator
# ============================================================================

[Replication-Monitor]
type=monitor
module=mariadbmon
servers=HORNOS, SANLORENZO, TUCUMAN
servers_no_promotion=TUCUMAN
user=maxscale
password=maxscale_pass
monitor_interval=2000ms
auto_failover=true
auto_rejoin=true
master_conditions=primary_monitor_master
cooperative_monitoring_locks=majority_of_all

# ============================================================================
# SERVICIO - Read/Write Routing
# ============================================================================

[Splitter-Service]
type=service
router=readconnroute
router_options=master
servers=HORNOS, SANLORENZO
user=maxscale
password=maxscale_pass
enable_root_user=true

# ============================================================================
# LISTENER - Puerto de acceso
# ============================================================================

[Splitter-Listener]
address=0.0.0.0
type=listener
service=Splitter-Service
protocol=MariaDBClient
port=4006