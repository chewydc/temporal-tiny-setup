    {
      "id": "h6qCfEHYD_WSqDT5DmBJI",
      "type": "text",
      "x": 4445.4585013352935,
      "y": 5757.789412702114,
      "width": 229.0953826559848,
      "height": 314.3612496128166,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
