    },
    {
      "id": "cmee66SnljktIcIUX-lqa",
      "type": "text",
      "x": 2056.8382076698217,
      "y": -825.0282200311276,
      "width": 171.38729295602477,
      "height": 235.77093720961247,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBk",
      "roundness": null,
      "seed": 1639231442,
      "version": 194,
      "versionNonce": 1661836522,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777034763544,
      "link": null,
      "locked": false,
      "text": "📌 Sin Elasticsearch:\n\nPodés:\n- ejecutar workflows\n- verlos por ID\n\nNo podés bien:\n- listar por fecha\n- filtrar por estado\n- buscar por atributos\n- En escala grande,\nsin ES es inviable.",
      "fontSize": 15.718062480640832,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "📌 Sin Elasticsearch:\n\nPodés:\n- ejecutar workflows\n- verlos por ID\n\nNo podés bien:\n- listar por fecha\n- filtrar por estado\n- buscar por atributos\n- En escala grande, sin ES es inviable.",
      "autoResize": false,
      "lineHeight": 1.25
    },
