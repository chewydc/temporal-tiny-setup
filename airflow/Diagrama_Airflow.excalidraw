      "link": null,
      "locked": false,
      "text": "Shared Library:\nContiene librerias\ncompartidas entre\nsubgrupos/repos.\nPermite compartir y\nreutilizar codigo.\n\nPensado para conectores,\netc.\n",
      "fontSize": 15.718062480640832,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Shared Library:\nContiene librerias compartidas entre subgrupos/repos.\nPermite compartir y reutilizar codigo.\n\nPensado para conectores, etc.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
