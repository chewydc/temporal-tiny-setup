    {
      "id": "OZBF37YPTkB-_a_kwfOpr",
      "type": "text",
      "x": 10835.810687202456,
      "y": 7394.622911338158,
      "width": 349.118691483485,
      "height": 98.2378905040052,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
