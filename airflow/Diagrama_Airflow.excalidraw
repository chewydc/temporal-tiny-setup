    {
      "id": "9NImb2EbINOYbwGWsNOHg",
      "type": "text",
      "x": 643.3160097316013,
      "y": 627.5895565731696,
      "width": 349.118691483485,
      "height": 98.2378905040052,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
